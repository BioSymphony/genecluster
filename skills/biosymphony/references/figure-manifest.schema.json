{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://biosymphony.local/schemas/figure-manifest.schema.json",
  "title": "BioSymphony Figure Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "campaign",
    "created_at",
    "inputs",
    "artifacts",
    "software",
    "linear",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "campaign": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "template": { "type": "string" }
      },
      "additionalProperties": true
    },
    "created_at": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/file_or_source"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "software": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "path": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "linear": {
      "type": "object",
      "properties": {
        "project": { "type": "string" },
        "campaign_label": { "type": "string" },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "status"],
        "properties": {
          "command": { "type": "string" },
          "status": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "file_or_source": {
      "type": "object",
      "required": ["id", "kind", "source"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "source": { "type": "string" },
        "path": { "type": "string" },
        "sha256": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "artifact": {
      "type": "object",
      "required": ["path", "kind"],
      "properties": {
        "path": { "type": "string" },
        "kind": { "type": "string" },
        "producer_issue": { "type": "string" },
        "sha256": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
